[Unit]
Description=Vigilante SEACE QA - Telegram Bot Listener
After=network.target mysql.service
Wants=mysql.service
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/vigilante-seace-qa

ExecStart=/usr/local/php82/bin/php artisan telegram:listen

KillSignal=SIGTERM
KillMode=mixed
TimeoutStopSec=20

Restart=on-failure
RestartSec=30
StandardOutput=append:/var/log/vigilante-seace-qa/telegram-bot.log
StandardError=append:/var/log/vigilante-seace-qa/telegram-bot-error.log

NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/www/vigilante-seace-qa/storage /var/log/vigilante-seace-qa /tmp

[Install]
WantedBy=multi-user.target
