APP_NAME="Vigilante SEACE"
APP_ENV=local
# APP_ENV: local | staging | production
# staging  → qa.licitacionesmype.pe  (noindex, no GA)
# production → licitacionesmype.pe   (indexable, con GA)
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =====================================================
# CONFIGURACIÓN DE BASE DE DATOS (MySQL)
# =====================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vigilante_seace
DB_USERNAME=root
DB_PASSWORD=

# =====================================================
# CONFIGURACIÓN DE SESIÓN Y CACHE
# =====================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =====================================================
# CONFIGURACIÓN DE CORREO (MailerSend SMTP)
# =====================================================
# Para desarrollo usar MAIL_MAILER=log (no envía correos reales)
# ⚠️  En QA y producción debe estar configurado con credenciales reales
#     de MailerSend para que funcionen las notificaciones por email.
#
#   Ambiente      MAIL_MAILER    MAIL_FROM_ADDRESS
#   ──────────    ───────────    ─────────────────────────────
#   Local/dev     log            (no importa)
#   QA            smtp           noreply@licitacionesmype.pe
#   Producción    smtp           noreply@licitacionesmype.pe
#
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailersend.net
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@licitacionesmype.pe
MAIL_FROM_NAME="${APP_NAME}"

# =====================================================
# CONFIGURACIÓN DE AWS (OPCIONAL)
# =====================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =====================================================
# CONFIGURACIÓN DE SEACE (OBLIGATORIO)
# =====================================================
# URL base de la API del SEACE
SEACE_BASE_URL=https://prod6.seace.gob.pe/v1/s8uit-services

# RUC del proveedor (10 dígitos) - Ejemplo: 10XXXXXXXX
SEACE_RUC_PROVEEDOR=

# Contraseña de acceso al portal SEACE
SEACE_PASSWORD=

# Duración del token en cache (segundos) - Por defecto: 3600 (1 hora)
SEACE_TOKEN_CACHE_DURATION=3600

# =====================================================
# ENDPOINTS DE SEACE (No modificar)
# =====================================================
SEACE_ENDPOINT_LOGIN=/seguridadproveedor/seguridad/validausuariornp
SEACE_ENDPOINT_REFRESH=/seguridadproveedor/seguridad/tokens/refresh
SEACE_ENDPOINT_BUSCADOR=/contratacion/contrataciones/buscador
SEACE_ENDPOINT_OBJETO_CONTRATACION=/maestra/maestras/listar-objeto-contratacion
SEACE_ENDPOINT_ESTADO_CONTRATACION=/maestra/maestras/listar-estado-contratacion
SEACE_ENDPOINT_DEPARTAMENTOS=/maestra/maestras/listar-departamento

# =====================================================
# CONFIGURACIÓN DE TELEGRAM (OBLIGATORIO)
# =====================================================
# URL base del Bot API de Telegram
TELEGRAM_API_BASE=https://api.telegram.org

# Token del Bot de Telegram - Obtener desde @BotFather
# ⚠️  CADA AMBIENTE NECESITA SU PROPIO BOT (Telegram solo permite 1 polling por token)
#
#   Ambiente      Bot sugerido               Token
#   ──────────    ────────────────────────    ─────
#   Producción    @LicitacionesMYPeBot       (tu token de prod)
#   QA            @LicitacionesMYPeQABot     (crear en @BotFather)
#   Local         @LicitacionesMYPeDevBot    (crear en @BotFather)
#
TELEGRAM_BOT_TOKEN=

# ID del chat donde se enviarán las notificaciones
# Obtener enviando un mensaje al bot y consultando:
# {API_BASE}/bot<TOKEN>/getUpdates
# Ejemplo: 123456789
TELEGRAM_CHAT_ID=

# Logs detallados de Telegram (true solo en dev/QA)
TELEGRAM_DEBUG_LOGS=false

# =====================================================
# TELEGRAM ADMIN BOT (Notificaciones internas)
# =====================================================
# Bot separado para notificar al admin sobre nuevos usuarios y suscripciones
# Obtener desde @BotFather (puede ser un bot diferente al de procesos)
# En QA/local puede apuntar a un chat de prueba
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# =====================================================
# CONFIGURACIÓN DE WHATSAPP BUSINESS (OPCIONAL)
# =====================================================
# Token de acceso de WhatsApp Cloud API
# Obtener desde Meta Developers > App > WhatsApp > API Setup
# Para producción usar System User Token (permanente)
WHATSAPP_TOKEN=

# ID del número de teléfono registrado en Meta Business
# Se obtiene en Meta Developers > WhatsApp > API Setup > Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=

# Versión de la Graph API de Meta (Ej: v22.0)
WHATSAPP_API_VERSION=v22.0

# Token secreto para verificar el webhook de Meta
# Debe coincidir con el configurado en Meta Developers > Webhooks
WHATSAPP_VERIFY_TOKEN=

# Timeout de peticiones HTTP a la API de WhatsApp (segundos)
WHATSAPP_TIMEOUT=15

# Habilitar logs detallados de las peticiones WhatsApp
WHATSAPP_DEBUG_LOGS=false

# Tiempo de caché para contexto de contratos en WhatsApp (minutos)
WHATSAPP_CONTRATO_CACHE_TTL=720

# Template de Meta para notificaciones (utility template con parámetros).
# Dejar vacío para usar hello_world como fallback para abrir conversación.
# Si se configura, debe ser un template aprobado por Meta con 3 parámetros:
# {{1}} = Entidad, {{2}} = Código contrato, {{3}} = Descripción
WHATSAPP_NOTIFICATION_TEMPLATE=

# =====================================================
# CONFIGURACIÓN DE SCRAPING (OPCIONAL)
# =====================================================
# Cantidad de registros por página (máximo: 100)
SEACE_PAGE_SIZE=100

# Delay aleatorio entre ejecuciones (en minutos)
SEACE_MIN_DELAY_MINUTES=42
SEACE_MAX_DELAY_MINUTES=50

# =====================================================
# ANALIZADOR TDR - MICROSERVICIO PYTHON (OPCIONAL)
# =====================================================
# URL del microservicio de análisis de TDRs con IA
# ⚠️  En VPS compartido: producción=puerto 8001, QA=puerto 8002
ANALIZADOR_TDR_URL=http://127.0.0.1:8001

# Habilitar/deshabilitar servicio de análisis
ANALIZADOR_TDR_ENABLED=false

# Timeout para análisis (segundos) - Recomendado: 60
ANALIZADOR_TDR_TIMEOUT=60

# Tamaño máximo de archivo (bytes) - Default: 10MB
ANALIZADOR_TDR_MAX_FILE_SIZE=10485760

# Proveedor de IA (gemini, openai)
ANALIZADOR_TDR_PROVIDER=gemini

# Modelo de IA a utilizar
ANALIZADOR_TDR_MODEL=gemini-2.5-flash

# Secreto compartido para JWT inter-servicio (HMAC-SHA256).
# Generar con: php -r "echo bin2hex(random_bytes(32));"
# DEBE ser idéntico en el .env del microservicio Python.
ANALIZADOR_TDR_SECRET=

# =====================================================
# PERSISTENCIA DE TDR Y CACHÉ DE ANÁLISIS
# =====================================================
# Disco de almacenamiento (local, s3)
TDR_STORAGE_DISK=local

# Carpeta raíz para archivos TDR
TDR_STORAGE_ROOT=tdr

# Tiempo de caché de análisis IA (minutos) - Default: 4320 (3 días)
TDR_ANALYSIS_CACHE_MINUTES=4320

# Tamaño mínimo (bytes) para que el análisis use Job async (queue:work).
# Local sin worker: 500000 (500 KB) → archivos pequeños van síncronos.
# QA / Producción: 0 → SIEMPRE async (vigilante-queue siempre activo).
TDR_ASYNC_MIN_SIZE_BYTES=500000

# =====================================================
# PASARELA DE PAGO
# =====================================================
# Pasarela activa: mercadopago | openpay
PAYMENT_GATEWAY=mercadopago

# ─── Mercado Pago (predeterminada) ───
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# ─── Openpay Perú (alternativa) ───
OPENPAY_MERCHANT_ID=
OPENPAY_PRIVATE_KEY=
OPENPAY_PUBLIC_KEY=
OPENPAY_PRODUCTION=false
OPENPAY_COUNTRY=PE
OPENPAY_CURRENCY=PEN
OPENPAY_WEBHOOK_SECRET=

# =====================================================
# REFERENCIA: CONFIGURACIÓN POR AMBIENTE
# =====================================================
# Ambiente     APP_ENV      APP_URL                          DB                    Telegram Bot       Analizador    Correo
# ──────────   ──────────   ──────────────────────────────   ──────────────────    ──────────────     ──────────    ──────────
# Producción   production   https://licitacionesmype.pe      vigilante_seace       @TuBotProd         :8001         smtp (MailerSend)
# QA           qa           https://qa.licitacionesmype.pe   vigilante_seace_qa    @TuBotQA           :8002         smtp (MailerSend)
# Local        local        http://localhost:8000            vigilante_seace       @TuBotDev          :8001         log (no envía)
#
# Deploy:  develop → QA (cd-qa.yml)  |  main → Producción (cd.yml)
# VPS QA:  /var/www/vigilante-seace-qa   (servicios con sufijo -qa)

